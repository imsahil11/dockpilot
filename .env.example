# PostgreSQL
POSTGRES_USER=dockpilot
POSTGRES_PASSWORD=dockpilot_secret
POSTGRES_DB=dockpilot
DATABASE_URL=postgresql://dockpilot:dockpilot_secret@postgres:5432/dockpilot

# Auth
JWT_SECRET=change_this_to_a_long_random_string_minimum_32_chars
JWT_EXPIRY=7d

# Anthropic
CLAUDE_API_KEY=sk-ant-your-key-here

# Alerts
ALERT_CPU_THRESHOLD=80
ALERT_MEMORY_THRESHOLD=90

# Optional SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Internal service URLs
BACKEND_URL=http://backend:4000
AI_SERVICE_URL=http://ai-service:8000
